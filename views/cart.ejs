<%- include('partials/header') %>

<section class="section">
  <div class="container">
    <h1 class="page-heading">Your Cart</h1>

    <% if (cart.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">🛒</div>
        <h2>Your cart is empty</h2>
        <p>Looks like you haven't added anything yet.</p>
        <a href="/products" class="btn btn-primary">Browse Products</a>
      </div>
    <% } else { %>
      <div class="cart-layout">
        <div class="cart-items">
          <% cart.forEach(item => { %>
            <div class="cart-item">
              <a href="/product/<%= item.slug %>" class="cart-item-image">
                <img src="<%= item.image %>" alt="<%= item.name %>">
              </a>
              <div class="cart-item-info">
                <a href="/product/<%= item.slug %>" class="cart-item-name"><%= item.name %></a>
                <span class="cart-item-price">€<%= item.price.toFixed(2) %></span>
              </div>
              <div class="cart-item-actions">
                <form action="/cart/update" method="POST" class="cart-qty-form">
                  <input type="hidden" name="itemId" value="<%= item.id %>">
                  <button type="submit" name="quantity" value="<%= item.quantity - 1 %>" class="qty-btn">−</button>
                  <span class="qty-display"><%= item.quantity %></span>
                  <button type="submit" name="quantity" value="<%= item.quantity + 1 %>" class="qty-btn">+</button>
                </form>
                <form action="/cart/remove" method="POST">
                  <input type="hidden" name="itemId" value="<%= item.id %>">
                  <button type="submit" class="remove-btn" title="Remove item">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                  </button>
                </form>
              </div>
              <div class="cart-item-subtotal">
                €<%= (item.price * item.quantity).toFixed(2) %>
              </div>
            </div>
          <% }) %>
        </div>

        <div class="cart-summary">
          <h3>Order Summary</h3>
          <div class="summary-row">
            <span>Subtotal</span>
            <span>€<%= cartTotal.toFixed(2) %></span>
          </div>
          <div class="summary-row">
            <span>Shipping</span>
            <span><%= cartTotal >= 100 ? 'Free' : '€4.99' %></span>
          </div>
          <% if (cartTotal < 100) { %>
            <div class="shipping-note">
              Add €<%= (100 - cartTotal).toFixed(2) %> more for free shipping!
            </div>
          <% } %>
          <div class="summary-row summary-total">
            <span>Total</span>
            <span>€<%= (cartTotal + (cartTotal >= 100 ? 0 : 4.99)).toFixed(2) %></span>
          </div>
          <a href="/checkout" class="btn btn-primary btn-lg btn-full">Proceed to Checkout</a>
          <a href="/products" class="continue-shopping">← Continue Shopping</a>
        </div>
      </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
