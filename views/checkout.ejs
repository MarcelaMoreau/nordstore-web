<%- include('partials/header') %>

<section class="section">
  <div class="container">
    <h1 class="page-heading">Checkout</h1>

    <div class="checkout-layout">
      <form action="/checkout/complete" method="POST" class="checkout-form">

        <div class="checkout-section">
          <h2>Contact Information</h2>
          <div class="form-row">
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="you@example.com" required>
            </div>
          </div>
          <div class="form-row form-row--half">
            <div class="form-group">
              <label for="firstName">First Name</label>
              <input type="text" id="firstName" name="firstName" placeholder="Jane" required>
            </div>
            <div class="form-group">
              <label for="lastName">Last Name</label>
              <input type="text" id="lastName" name="lastName" placeholder="Doe" required>
            </div>
          </div>
        </div>

        <div class="checkout-section">
          <h2>Shipping Address</h2>
          <div class="form-row">
            <div class="form-group">
              <label for="address">Address</label>
              <input type="text" id="address" name="address" placeholder="123 Example Street" required>
            </div>
          </div>
          <div class="form-row form-row--half">
            <div class="form-group">
              <label for="city">City</label>
              <input type="text" id="city" name="city" placeholder="Berlin" required>
            </div>
            <div class="form-group">
              <label for="postal">Postal Code</label>
              <input type="text" id="postal" name="postalCode" placeholder="10115" required>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="country">Country</label>
              <select id="country" name="country">
                <option value="DE" selected>Germany</option>
                <option value="AT">Austria</option>
                <option value="CH">Switzerland</option>
                <option value="FR">France</option>
                <option value="NL">Netherlands</option>
                <option value="US">United States</option>
                <option value="GB">United Kingdom</option>
              </select>
            </div>
          </div>
        </div>

        <div class="checkout-section">
          <h2>Payment <span class="demo-note">(Demo — no real payment)</span></h2>
          <div class="form-row">
            <div class="form-group">
              <label for="cardNumber">Card Number</label>
              <input type="text" id="cardNumber" name="cardNumber" placeholder="4242 4242 4242 4242" maxlength="19">
            </div>
          </div>
          <div class="form-row form-row--third">
            <div class="form-group">
              <label for="expiry">Expiry</label>
              <input type="text" id="expiry" name="expiry" placeholder="MM/YY" maxlength="5">
            </div>
            <div class="form-group">
              <label for="cvc">CVC</label>
              <input type="text" id="cvc" name="cvc" placeholder="123" maxlength="4">
            </div>
          </div>
        </div>

        <div class="checkout-actions">
          <button type="submit" class="btn btn-primary btn-lg btn-full">Place Order — €<%= (cartTotal + (cartTotal >= 100 ? 0 : 4.99)).toFixed(2) %></button>
        </div>
      </form>

      <div class="cart-summary checkout-summary">
        <h3>Your Order</h3>
        <% cart.forEach(item => { %>
          <div class="summary-item">
            <img src="<%= item.image %>" alt="<%= item.name %>">
            <div>
              <span class="summary-item-name"><%= item.name %></span>
              <span class="summary-item-qty">Qty: <%= item.quantity %></span>
            </div>
            <span class="summary-item-price">€<%= (item.price * item.quantity).toFixed(2) %></span>
          </div>
        <% }) %>
        <div class="summary-row">
          <span>Subtotal</span>
          <span>€<%= cartTotal.toFixed(2) %></span>
        </div>
        <div class="summary-row">
          <span>Shipping</span>
          <span><%= cartTotal >= 100 ? 'Free' : '€4.99' %></span>
        </div>
        <div class="summary-row summary-total">
          <span>Total</span>
          <span>€<%= (cartTotal + (cartTotal >= 100 ? 0 : 4.99)).toFixed(2) %></span>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
