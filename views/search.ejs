<%- include('partials/header') %>

<section class="section">
  <div class="container">
    <h1 class="page-heading">Search results for "<%= query %>"</h1>

    <% if (results.length === 0) { %>
      <div class="empty-state">
        <h2>No results found</h2>
        <p>Try a different search term or <a href="/products">browse all products</a>.</p>
      </div>
    <% } else { %>
      <p class="results-count"><%= results.length %> product<%= results.length !== 1 ? 's' : '' %> found</p>
      <div class="product-grid">
        <% results.forEach(product => { %>
          <%- include('partials/product-card', { product }) %>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
